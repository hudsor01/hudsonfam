# Cloudflare R2 — object storage for photo originals + derivatives
# Create bucket + S3 API token at: Cloudflare Dashboard -> R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT="https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com"
# Optional: public bucket URL if you enable public access; omit to proxy reads through /api/images
R2_PUBLIC_URL=""

# Webhook secret for n8n (HMAC-SHA256 shared secret)
N8N_WEBHOOK_SECRET=""
